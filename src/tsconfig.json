{
  "extends": "../tsconfig.nuxt.json",
  "include": [
    "../.nuxt/**/*.d.ts",
    "../.nuxt/**/*.ts",
    "./**/*.ts",
    "./**/*.mts",
    "./**/*.d.ts",
    "./**/*.vue"
  ],
