{
  "name": "personal",
  "description": "Fixture-backed personal Trellis starter.",
  "include": [
    ".env.example",
    ".gitignore",
    "AGENTS.md",
    "README.md",
    "app/**",
    "convex/**/*.ts",
    "nuxt.config.ts",
    "package.json",
    "tsconfig.json",
    "server/**",
    "shared/**/*.ts"
  ],
  "exclude": [
    ".convex/**",
    ".env.local",
    ".nuxt/**",
    ".output/**",
    "node_modules/**",
    "coverage/**"
  ],
  "generatedPaths": [
    ".env.example",
    ".gitignore",
    "AGENTS.md",
    "README.md",
    "package.json",
    "tsconfig.json",
    "server/api/.gitkeep",
    "server/mcp/.gitkeep",
    "convex/auth.config.ts",
    "convex/convex.config.ts",
    "convex/http.ts",
    "convex/test.setup.ts"
  ]
}
