{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "noEmitOnError": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["src/cli.mts", "src/cli/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/cli/starter-fixtures", "src/cli/add-fixtures"]
}
