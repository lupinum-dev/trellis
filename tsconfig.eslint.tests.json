{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.mts",
    "src/**/*.d.ts",
    "tests/**/*.ts",
    "tests/**/*.mts",
    "tests/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "apps/devtools-ui",
    "apps/harness/.nuxt",
    "apps/harness/.output",
    "apps/docs",
    "examples",
    "labs",
    "tests/fixtures/*/node_modules",
    "tests/fixtures/*/.nuxt",
    "tests/fixtures/*/.output"
  ]
}
