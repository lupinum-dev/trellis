{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [".nuxt/**/*.d.ts", ".nuxt/**/*.ts", "tests/types/**/*.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "apps/harness",
    "tests/fixtures",
    "examples",
    "tests/types/component-bridge.types.ts"
  ]
}
