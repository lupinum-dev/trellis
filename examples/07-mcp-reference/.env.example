# Trusted-forwarding auth reads this value from the local Convex environment.
CONVEX_IDENTITY_FORWARDING_KEY=replace-me-with-the-same-value-you-use-for-local-dev
TRELLIS_MCP_CONFIRMATION_KEY=replace-me-with-a-second-shared-secret-for-destructive-mcp-tools
MCP_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379
MCP_REFERENCE_WEBHOOK_SECRET=replace-me-with-a-route-secret-for-the-webhook-example
MCP_REFERENCE_WEBHOOK_AUTH_ID=replace-me-with-a-real-user-or-bot-auth-id

# Convex Better Auth reads these values when you start the local Convex deployment.
SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
